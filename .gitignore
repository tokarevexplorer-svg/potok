# --- Секреты (главное!) ----------------------------------------------------
# Любые env-файлы — никогда в репозиторий. Даже .txt-копии (Windows иногда
# создаёт .env.txt чтобы открыть в блокноте — пусть тоже игнорируется).
.env
.env.*
*.env
*.env.txt
*.env.local.txt
# Допускаем только примеры без реальных ключей:
!.env.example
!**/.env.example

# --- Зависимости и сборки ---------------------------------------------------
node_modules/
.next/
out/
dist/
build/
.vercel/
.turbo/

# Кэш TypeScript
*.tsbuildinfo
next-env.d.ts

# --- Логи -------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- IDE и OS ---------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# --- Прочее -----------------------------------------------------------------
# Локальные настройки Claude Code (не код проекта)
.claude/
# Временные файлы и бэкапы
*.tmp
*.bak
