# Пример переменных окружения для бэкенда.
# Скопируй в .env и заполни реальными ключами. .env закоммичен быть не должен.

# Apify (https://console.apify.com/account/integrations)
APIFY_API_TOKEN=

# Supabase — НЕ anon-ключ, а service role (с правами записи, минует RLS).
# Dashboard → Project Settings → API → service_role key
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# На каком порту поднимать сервер локально. На Railway переменная подставляется автоматически — НЕ задавай её вручную в Railway.
PORT=3001

# Разрешённые источники для CORS (через запятую). Для локалки — Next dev-сервер.
# В проде — добавь URL фронтенда на Vercel, например:
#   FRONTEND_ORIGINS=https://potok-app.vercel.app,http://localhost:3000
FRONTEND_ORIGINS=http://localhost:3000

# Instagram-скрапер на Apify. По умолчанию apify/instagram-scraper.
APIFY_ACTOR_ID=apify/instagram-scraper

# OpenAI — используется и для Whisper (транскрипция), и для саммари/категоризации.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Модель транскрипции. По умолчанию whisper-1.
OPENAI_WHISPER_MODEL=whisper-1
# Модель саммари/категоризации. По умолчанию gpt-4o-mini (дёшево и достаточно).
OPENAI_ANALYSIS_MODEL=gpt-4o-mini

# Сколько видео обрабатывать одновременно при массовом добавлении.
# По умолчанию 2 — безопасно для Apify-плана и OpenAI rate-limit.
# Подними до 3–4, если уверен в лимитах. На тысячах ссылок это критично:
# 1000 видео при concurrency=2 ≈ 8 часов, при concurrency=4 ≈ 4 часа.
WORKER_CONCURRENCY=2

# --- Google Drive (постоянные превью) ---
# ВСЕ ТРИ ПЕРЕМЕННЫЕ ОПЦИОНАЛЬНЫЕ. Если не настроишь — превью продолжат
# жить на Instagram CDN и протухать через ~24 часа. Когда заполнишь —
# бэкенд автоматически начнёт перезаливать новые превью на Drive.
#
# Подготовка (один раз):
#  1. console.cloud.google.com → новый проект → Enable Google Drive API
#  2. Create Service Account → Keys → Add JSON. Скачать файл.
#  3. На Google Drive создать папку, например "potok-thumbnails".
#     Расшарить её на email сервисного аккаунта (роль Editor).
#  4. ID папки берётся из URL: drive.google.com/drive/folders/<ID>
#
# Локально: положи скачанный JSON в backend/google-credentials.json и укажи путь.
GOOGLE_DRIVE_CREDENTIALS_PATH=./google-credentials.json
# Альтернатива для Railway (он не позволяет загружать файлы): прокинуть
# содержимое JSON-ключа целиком как одну переменную. Если задана — она
# используется вместо PATH. Локально оставь пустой.
GOOGLE_DRIVE_CREDENTIALS_JSON=
# ID папки на Drive, в которую складывать превью.
GOOGLE_DRIVE_FOLDER_ID=
