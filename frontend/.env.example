# Supabase: публичный URL и anon-ключ. Используются и на сервере, и в браузере.
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL бэкенда. Используется только на сервере (Server Actions / API routes).
# Локально: http://127.0.0.1:3001 (именно 127.0.0.1, не localhost — см. CLAUDE.md).
# Прод: URL Railway-сервиса, например https://potok-backend-production.up.railway.app
BACKEND_URL=
